# Copy to .env for local development (never commit .env)

# Database — SQLite for dev, replace with postgresql+asyncpg://... for prod
DATABASE_URL=sqlite+aiosqlite:///./neuralgrid.db

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# CORS — comma-separated list of frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# Claude AI (optional — for LLM advisor features)
ANTHROPIC_API_KEY=

# Kafka (optional — leave empty to disable CIM Kafka transport)
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_GROUP_ID=neuralgrid-derms
